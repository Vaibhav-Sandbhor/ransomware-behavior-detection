# ============================================================
# MAD-CTI Configuration (Ollama - Local LLM)
# ============================================================
# No API key needed!  Ollama runs locally on your machine.
# Just install Ollama and pull a model:
#   1. Download from https://ollama.com/download
#   2. Run: ollama pull llama3.2
# ============================================================

# Optional -- Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Optional -- model to use (default: llama3.2)
MODEL_NAME=llama3.2

# Optional -- max tokens per agent call (default: 2048)
MAX_TOKENS=2048
